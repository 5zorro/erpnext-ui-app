# Copy to .env (never commit .env). Used by Playwright browser→ERP tests (layer 2).
# Create the user once (same sandbox as museum):
#   cd ~/agent-harness/erpnext/doc-shell && ./scripts/setup-playwright-user.sh
# Or from this repo after copying that script locally.

FRAPPE_SITE=frontend
ERP_URL=http://localhost:8080

# Dedicated sandbox user — not your daily Administrator login
ERP_USER=playwright-e2e@doc-shell.local
# Use double quotes if the password contains # ! $ or spaces
ERP_PW="choose-a-long-random-password-here"

# Optional: pass to setup-playwright-user.sh instead of ERP_PW
# PLAYWRIGHT_ERP_PW=choose-a-long-random-password-here
